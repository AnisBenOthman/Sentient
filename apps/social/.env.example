# ============================================================
# Social Service — Environment Variables Template
# ============================================================
# Copy to apps/social/.env and fill in values.
# This file IS committed. The actual .env is git-ignored.
# ============================================================

# ── Required (fail-fast on absence) ───────────────────────────────────────────
# PrismaService reads this via getOrThrow. Must include ?schema=social.
SOCIAL_DATABASE_URL=postgresql://social_svc:social_pass@localhost:5432/sentient?schema=social

# SharedJwtGuard — MUST match HR Core's JWT_SECRET exactly.
JWT_SECRET=change-me-in-production-minimum-32-random-characters

# SharedJwtGuard — SYSTEM-role tokens. MUST match HR Core's SYSTEM_JWT_SECRET.
SYSTEM_JWT_SECRET=change-me-system-secret-minimum-32-random-characters

# HrCoreClient base URL. Used by HrCoreClient.getOrThrow at construction.
HR_CORE_URL=http://localhost:3001

# ── Optional (safe defaults shown) ────────────────────────────────────────────
# Port Social listens on. Defaults to 3002.
SOCIAL_PORT=3002

# In-process employee-ref cache TTL in milliseconds. Defaults to 60000 (1 min).
HR_CORE_EMPLOYEE_CACHE_TTL_MS=60000

# CORS allowlist origin. Defaults to http://localhost:3000.
FRONTEND_URL=http://localhost:3000

# ThrottlerModule window in milliseconds. Defaults to 60000.
THROTTLE_TTL=60000

# Maximum requests per IP per THROTTLE_TTL window. Defaults to 100.
THROTTLE_LIMIT=100

# Route handler timeout in milliseconds. Defaults to 30000.
REQUEST_TIMEOUT_MS=30000

# JWT expiry duration (reserved; Social does not mint tokens today). Defaults to 15m.
JWT_EXPIRY=15m
