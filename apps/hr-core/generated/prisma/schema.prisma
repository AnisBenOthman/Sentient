datasource db {
  provider = "postgresql"
  url      = env("HR_CORE_DATABASE_URL")
  schemas  = ["hr_core"]
}

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["multiSchema"]
}

// ============================================================
// ENUMS
// ============================================================

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  PROBATION
  TERMINATED
  RESIGNED

  @@schema("hr_core")
}

enum ContractType {
  FULL_TIME
  PART_TIME
  INTERN
  CONTRACTOR
  FIXED_TERM

  @@schema("hr_core")
}

// ============================================================
// DOMAIN: Organization Structure
// ============================================================

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  headId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams     Team[]
  employees Employee[]

  @@index([isActive])
  @@map("departments")
  @@schema("hr_core")
}

model Team {
  id           String   @id @default(uuid())
  name         String
  code         String?  @unique
  description  String?
  departmentId String
  leadId       String?
  projectFocus String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@index([departmentId])
  @@index([isActive])
  @@map("teams")
  @@schema("hr_core")
}

model Position {
  id        String   @id @default(uuid())
  title     String   @unique
  level     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  employees Employee[]

  @@index([isActive])
  @@map("positions")
  @@schema("hr_core")
}

// ============================================================
// DOMAIN: Employees & Compensation
// WHY: Employee is the central aggregate. All HR workflows
// (leaves, performance, probation, complaints) reference it.
// SalaryHistory is co-located because compensation is tightly
// coupled to the employee lifecycle — not a separate domain.
// ============================================================

model Employee {
  id               String           @id @default(uuid())
  employeeCode     String           @unique
  firstName        String
  lastName         String
  email            String           @unique
  phone            String?
  dateOfBirth      DateTime?
  hireDate         DateTime
  employmentStatus EmploymentStatus @default(ACTIVE)
  contractType     ContractType     @default(FULL_TIME)
  currentSalary    Decimal?         @db.Decimal(12, 2)
  positionId       String?
  departmentId     String?
  teamId           String?
  managerId        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  position      Position?       @relation(fields: [positionId], references: [id])
  department    Department?     @relation(fields: [departmentId], references: [id])
  team          Team?           @relation(fields: [teamId], references: [id])
  manager       Employee?       @relation("EmployeeManager", fields: [managerId], references: [id])
  directReports Employee[]      @relation("EmployeeManager")
  salaryHistory SalaryHistory[]

  @@index([departmentId])
  @@index([teamId])
  @@index([employmentStatus])
  @@index([positionId])
  @@index([managerId])
  @@index([email])
  @@map("employees")
  @@schema("hr_core")
}

model SalaryHistory {
  id             String   @id @default(uuid())
  employeeId     String
  previousSalary Decimal  @db.Decimal(12, 2)
  newSalary      Decimal  @db.Decimal(12, 2)
  effectiveDate  DateTime
  reason         String?
  changedById    String
  createdAt      DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([effectiveDate])
  @@map("salary_history")
  @@schema("hr_core")
}
