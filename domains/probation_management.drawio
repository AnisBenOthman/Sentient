<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="Probation Management" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="1100" height="780" as="geometry"/>
    </mxCell>

    <!-- ACTORS (left side) -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="100" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_mgr" value="Manager" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="330" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="540" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- ACTORS (right side) -->
    <mxCell id="a_sys" value="System&#xa;(Scheduler)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1400" y="100" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_ai" value="AI Onboarding&#xa;Companion" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="1400" y="350" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization (left actors) -->
    <mxCell id="gen1" edge="1" parent="1" source="a_mgr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="gen2" edge="1" parent="1" source="a_hr" target="a_mgr" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ════════════════ Row 1 — Employee Use Cases ════════════════ -->
    <mxCell id="uc_view_prob" value="View Probation Status" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="60" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_self_eval" value="Submit Self-Evaluation" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="60" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_download" value="Download Confirmation&#xa;Letter" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="60" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Row 2 — Employee continued -->
    <mxCell id="uc_chat_ai" value="Chat with Onboarding&#xa;Companion" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="180" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- ════════════════ Row 3 — Manager Use Cases ════════════════ -->
    <mxCell id="uc_mgr_eval" value="Submit Manager&#xa;Evaluation" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="310" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_decide" value="Make Probation&#xa;Decision" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="310" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_view_hints" value="View AI Risk Hints" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="870" y="310" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_view_team" value="View Team Probation&#xa;Dashboard" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="420" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- ════════════════ Row 4 — HR Admin Use Cases ════════════════ -->
    <mxCell id="uc_config" value="Manage Probation&#xa;Policy" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="540" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_cfg_duration" value="Configure Duration&#xa;per Structure" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="580" y="520" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_cfg_ext" value="Configure Extension&#xa;Rules" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="870" y="520" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_overview" value="View All Probations&#xa;Overview" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="660" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- ════════════════ Row 5 — System / AI Use Cases ════════════════ -->
    <mxCell id="uc_trigger" value="Trigger Evaluation&#xa;Window (T-14)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="130" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_gen_letter" value="Generate Confirmation&#xa;Letter (PDF)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="430" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_welcome" value="Send Welcome&#xa;Message (Day 1)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="630" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_checkin" value="Send Periodic&#xa;Check-ins" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="680" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_risk" value="Generate Risk&#xa;Hints" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="730" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- ════════════════ ACTOR → USE CASE EDGES ════════════════ -->

    <!-- Employee edges -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_view_prob" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_self_eval" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_emp" target="uc_download" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_emp" target="uc_chat_ai" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Manager edges -->
    <mxCell id="e5" edge="1" parent="1" source="a_mgr" target="uc_mgr_eval" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_mgr" target="uc_decide" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_mgr" target="uc_view_team" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- HR Admin edges -->
    <mxCell id="e8" edge="1" parent="1" source="a_hr" target="uc_config" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e9" edge="1" parent="1" source="a_hr" target="uc_overview" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- System edges -->
    <mxCell id="e10" edge="1" parent="1" source="a_sys" target="uc_trigger" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e11" edge="1" parent="1" source="a_sys" target="uc_gen_letter" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- AI Companion edges -->
    <mxCell id="e12" edge="1" parent="1" source="a_ai" target="uc_welcome" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e13" edge="1" parent="1" source="a_ai" target="uc_checkin" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e14" edge="1" parent="1" source="a_ai" target="uc_risk" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e15" edge="1" parent="1" source="a_ai" target="uc_chat_ai" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ════════════════ RELATIONSHIPS ════════════════ -->

    <!-- include: Manage Policy → Configure Duration -->
    <mxCell id="r1" value="«include»" edge="1" parent="1" source="uc_config" target="uc_cfg_duration" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- include: Manage Policy → Configure Extension -->
    <mxCell id="r2" value="«include»" edge="1" parent="1" source="uc_config" target="uc_cfg_ext" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- include: Make Decision → View AI Risk Hints -->
    <mxCell id="r3" value="«include»" edge="1" parent="1" source="uc_decide" target="uc_view_hints" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#D6B656;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- include: Make Decision → Generate Letter (on CONFIRM) -->
    <mxCell id="r4" value="«include»&#xa;(on CONFIRM)" edge="1" parent="1" source="uc_decide" target="uc_gen_letter" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#999;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <!-- include: Trigger Eval → Generate Risk Hints -->
    <mxCell id="r5" value="«include»" edge="1" parent="1" source="uc_trigger" target="uc_risk" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#9673A6;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ════════════════ ENUMS ════════════════ -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="835" width="160" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="e_ps" value="«enumeration»&#xa;ProbationStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="870" width="220" height="166" as="geometry"/>
    </mxCell>
    <mxCell id="e_psv" value="ACTIVE&#xa;EVALUATION_PENDING&#xa;EVALUATION_SUBMITTED&#xa;CONFIRMED&#xa;TERMINATED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ps">
      <mxGeometry x="0" y="36" width="220" height="130" as="geometry"/>
    </mxCell>

    <mxCell id="e_pd" value="«enumeration»&#xa;ProbationDecision" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="470" y="870" width="220" height="112" as="geometry"/>
    </mxCell>
    <mxCell id="e_pdv" value="CONFIRM&#xa;EXTEND&#xa;TERMINATE" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_pd">
      <mxGeometry x="0" y="36" width="220" height="76" as="geometry"/>
    </mxCell>

    <mxCell id="e_pet" value="«enumeration»&#xa;ProbationEvaluatorType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="720" y="870" width="220" height="94" as="geometry"/>
    </mxCell>
    <mxCell id="e_petv" value="SELF&#xa;MANAGER" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_pet">
      <mxGeometry x="0" y="36" width="220" height="58" as="geometry"/>
    </mxCell>

    <mxCell id="e_pp" value="«enumeration»&#xa;ProbationPhase" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="970" y="870" width="220" height="94" as="geometry"/>
    </mxCell>
    <mxCell id="e_ppv" value="INITIAL&#xa;EXTENSION" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_pp">
      <mxGeometry x="0" y="36" width="220" height="58" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
