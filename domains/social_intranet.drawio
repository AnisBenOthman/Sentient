    <mxCell id="e_fbt" value="«enumeration»&#xa;FeedbackType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="980" y="765" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_fbtv" value="EVENT&#xa;GENERAL&#xa;SUGGESTION&#xa;PULSE" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_fbt">
