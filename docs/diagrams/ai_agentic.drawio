    <mxCell id="e_tt" value="«enumeration»&#xa;TaskTrigger" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="480" y="725" width="220" height="112" as="geometry"/>
    </mxCell>
    <mxCell id="e_ttv" value="USER&#xa;SYSTEM&#xa;SCHEDULE" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_tt">
      <mxGeometry x="0" y="36" width="220" height="76" as="geometry"/>
    </mxCell>

    <mxCell id="e_ts" value="«enumeration»&#xa;TaskStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
