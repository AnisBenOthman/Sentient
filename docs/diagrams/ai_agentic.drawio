<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="AI Agentic Service" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="1100" height="640" as="geometry"/>
    </mxCell>

    <!-- ACTORS -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="160" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_mgr" value="Manager" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="410" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="540" width="50" height="75" as="geometry"/>
    </mxCell>
    <!-- External: OpenAI -->
    <mxCell id="a_openai" value="OpenAI&#xa;GPT-4o" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=12;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="1380" y="280" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization -->
    <mxCell id="gen1" edge="1" parent="1" source="a_mgr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="gen2" edge="1" parent="1" source="a_hr" target="a_mgr" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Row 1 — Conversations -->
    <mxCell id="uc_chat" value="Chat with AI Assistant" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_hist" value="View Conversation&#xa;History" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="75" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="uc_policy" value="Ask HR Policy /&#xa;Q&amp;A" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="870" y="75" width="220" height="70" as="geometry"/>
    </mxCell>

    <!-- Row 2 — Employee Agents -->
    <mxCell id="uc_sick" value="Process Sick Leave&#xa;(Leave Agent)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="290" y="205" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="uc_career" value="Get Career Advice&#xa;(Career Agent)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="580" y="205" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="uc_reword" value="Reword Message&#xa;(Linguistic Agent)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="870" y="205" width="220" height="70" as="geometry"/>
    </mxCell>

    <!-- Row 3 — Manager -->
    <mxCell id="uc_analytics" value="View Analytics&#xa;Dashboard" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="390" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_sql" value="Text-to-SQL Query&#xa;(Analytics Agent)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="580" y="390" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Row 4 — HR Admin -->
    <mxCell id="uc_engage" value="Generate Engagement&#xa;Report (Engagement Agent)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="525" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="uc_audit" value="View Agent Audit&#xa;Log" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="525" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="uc_rag" value="Search Policy&#xa;Documents (RAG)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="870" y="525" width="220" height="70" as="geometry"/>
    </mxCell>

    <!-- ACTOR EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_chat" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_hist" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_mgr" target="uc_analytics" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_hr" target="uc_engage" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="a_hr" target="uc_audit" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_openai" target="uc_policy" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_openai" target="uc_rag" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RELATIONSHIPS -->
    <mxCell id="r1" value="«extend»" edge="1" parent="1" source="uc_sick" target="uc_chat" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#6C8EBF;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r2" value="«extend»" edge="1" parent="1" source="uc_career" target="uc_chat" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#6C8EBF;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r3" value="«extend»" edge="1" parent="1" source="uc_policy" target="uc_chat" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#999;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r4" value="«include»" edge="1" parent="1" source="uc_analytics" target="uc_sql" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#D6B656;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r5" value="«include»" edge="1" parent="1" source="uc_policy" target="uc_rag" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RBAC note -->
    <mxCell id="note1" value="Agents inherit requesting&#xa;user's JWT (RBAC enforced)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="870" y="390" width="215" height="55" as="geometry"/>
    </mxCell>

    <!-- ENUMS -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="690" width="160" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="e_at" value="«enumeration»&#xa;AgentType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="725" width="230" height="202" as="geometry"/>
    </mxCell>
    <mxCell id="e_atv" value="HR_ASSISTANT&#xa;LEAVE_AGENT&#xa;CAREER_AGENT&#xa;LINGUISTIC_AGENT&#xa;ANALYTICS_AGENT&#xa;ENGAGEMENT_AGENT&#xa;ONBOARDING_COMPANION" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_at">
      <mxGeometry x="0" y="36" width="230" height="166" as="geometry"/>
