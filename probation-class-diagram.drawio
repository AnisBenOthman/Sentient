    <mxCell id="ev21" value="+ submittedAt : DateTime?  (null = draft)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;overflow=hidden;rotatable=0;" vertex="1" parent="ProbationEvaluation">
      <mxGeometry x="0" y="650" width="380" height="26" as="geometry"/>
    </mxCell>
    <mxCell id="ev22" value="+ createdAt : DateTime" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;overflow=hidden;rotatable=0;" vertex="1" parent="ProbationEvaluation">
      <mxGeometry x="0" y="676" width="380" height="26" as="geometry"/>
    </mxCell>

    <!-- ================================================================
         COLUMN 2 (x=370): State Machine Diagram (below ProbationPolicy)
         ================================================================ -->

    <mxCell id="sm_box" value="Probation State Machine" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=13;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=1;spacingTop=5;arcSize=8;" vertex="1" parent="1">
      <mxGeometry x="40" y="640" width="600" height="340" as="geometry"/>
    </mxCell>

    <mxCell id="sm_active" value="ACTIVE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="80" y="700" width="110" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="sm_eval_pend" value="EVALUATION&#xa;PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="260" y="700" width="110" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="sm_eval_sub" value="EVALUATION&#xa;SUBMITTED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="440" y="700" width="110" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="sm_confirmed" value="CONFIRMED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="440" y="800" width="110" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="sm_terminated" value="TERMINATED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="440" y="880" width="110" height="36" as="geometry"/>
    </mxCell>

    <!-- State transitions -->
    <mxCell id="sm_t1" value="T-14 days" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;fontSize=10;" edge="1" source="sm_active" target="sm_eval_pend" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="sm_t2" value="both evals done" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;fontSize=10;" edge="1" source="sm_eval_pend" target="sm_eval_sub" parent="1">
