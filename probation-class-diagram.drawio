    </mxCell>
    <mxCell id="sm_t3" value="CONFIRM" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;fontSize=10;" edge="1" source="sm_eval_sub" target="sm_confirmed" parent="1">
      <mxGeometry relative="1" as="geometry"/>
