    <mxCell id="sm_t4" value="TERMINATE" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;fontSize=10;" edge="1" source="sm_eval_sub" target="sm_terminated" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="sm_t5" value="EXTEND&#xa;(max 1)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;fontSize=10;curved=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;" edge="1" source="sm_eval_sub" target="sm_active" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="80" y="718"/>
          <mxPoint x="80" y="770"/>
        </Array>
      </mxGeometry>
    </mxCell>

