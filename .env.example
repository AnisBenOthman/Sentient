# ============================================================
# Sentient HRIS — Environment Variables Template
# ============================================================
# Copy this file to .env in each service directory and fill in values.
# Root .env is NOT loaded by services — each service loads its own .env.
# DO NOT commit real .env files. This .env.example IS committed.
# ============================================================

# ── Shared / Cross-Service ──────────────────────────────────────────────────
# Used by all 3 NestJS services for JWT signing/validation.
# MUST be identical in all services for tokens to validate cross-service.
JWT_SECRET=change-me-in-production-minimum-32-random-characters
JWT_EXPIRY=15m

# System-role JWTs (minted by AI Agentic for scheduled/push tasks)
SYSTEM_JWT_SECRET=change-me-system-secret-minimum-32-random-characters
SYSTEM_JWT_EXPIRY=5m

# ── OpenAI (AI Agentic service, Month 4+) ──────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Docker Database (root .env) ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_password
POSTGRES_DB=sentient

# ── HR Core Service (apps/hr-core/.env) ────────────────────────────────────
HR_CORE_DATABASE_URL=postgresql://hr_core_svc:hr_core_pass@localhost:5432/sentient?schema=hr_core
HR_CORE_PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Social Service (apps/social/.env) ──────────────────────────────────────
SOCIAL_DATABASE_URL=postgresql://social_svc:social_pass@localhost:5432/sentient?schema=social
SOCIAL_PORT=3002
# HR_CORE_URL is used by Social to call HR Core for employee data
HR_CORE_URL=http://localhost:3001

# ── AI Agentic Service (apps/ai-agentic/.env) ──────────────────────────────
AI_AGENT_DATABASE_URL=postgresql://ai_agent_svc:ai_pass@localhost:5432/sentient?schema=ai_agent
# Read-only analytics connection (ai_analytics_readonly role, hr_core schema)
AI_ANALYTICS_DATABASE_URL=postgresql://ai_analytics_readonly:readonly_pass@localhost:5432/sentient?schema=hr_core
AI_AGENT_PORT=3003
# AI Agentic calls both HR Core and Social
# HR_CORE_URL=http://localhost:3001  (same as above)
SOCIAL_URL=http://localhost:3002

# ── Exit Survey & Scoped Tokens (Social service, Month 3+) ─────────────────
SURVEY_TOKEN_SECRET=change-me-survey-token-secret-minimum-32-chars
SURVEY_TOKEN_EXPIRY_DAYS=14

# ── Notification Channels (Month 4+) ───────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Middleware / Rate Limiting / Timeouts ──────────────────────────────────
# ThrottlerModule: requests allowed per IP per window (applies to all 3 services)
# TTL is in milliseconds — 60000 = 1 minute
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Route handler timeout in milliseconds (default 30s for hr-core and social)
# For ai-agentic, set to 60000 — LLM agent chains can take 15-45s
REQUEST_TIMEOUT_MS=30000

# ── Next.js Frontend (apps/web/.env.local) ─────────────────────────────────
# NEXT_PUBLIC_ prefix exposes variables to the browser
NEXT_PUBLIC_HR_CORE_URL=http://localhost:3001
NEXT_PUBLIC_SOCIAL_URL=http://localhost:3002
NEXT_PUBLIC_AI_URL=http://localhost:3003
