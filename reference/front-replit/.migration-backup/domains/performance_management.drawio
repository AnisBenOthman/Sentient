<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="Performance Management" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="900" height="500" as="geometry"/>
    </mxCell>

    <!-- ACTORS -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="110" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_mgr" value="Manager" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="290" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="420" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization -->
    <mxCell id="gen1" edge="1" parent="1" source="a_mgr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="gen2" edge="1" parent="1" source="a_hr" target="a_mgr" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Row 1 — Employee -->
    <mxCell id="uc_self" value="Submit Self-Review" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_view" value="View Own&#xa;Performance Review" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="75" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="uc_goals" value="View Personal Goals" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="80" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 2 — Manager -->
    <mxCell id="uc_conduct" value="Conduct Team&#xa;Performance Review" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="265" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_teamsummary" value="View Team Review&#xa;Summary" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="265" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Row 3 — HR Admin -->
    <mxCell id="uc_initiate" value="Initiate Review Cycle" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="415" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_allrev" value="View All Reviews&#xa;(Global)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="415" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_sal" value="Update Salary History&#xa;Post-Review" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="415" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- ACTOR EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_self" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_view" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_emp" target="uc_goals" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_mgr" target="uc_conduct" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="a_mgr" target="uc_teamsummary" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_hr" target="uc_initiate" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_hr" target="uc_allrev" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8" edge="1" parent="1" source="a_hr" target="uc_sal" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RELATIONSHIPS -->
    <mxCell id="r1" value="«extend»" edge="1" parent="1" source="uc_self" target="uc_initiate" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#999;"><mxGeometry relative="1" as="geometry">
      <Array as="points"><mxPoint x="400" y="480"/></Array>
    </mxGeometry></mxCell>
    <mxCell id="r2" value="«include»" edge="1" parent="1" source="uc_conduct" target="uc_self" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#D6B656;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Note: self-review only during active cycle -->
    <mxCell id="note1" value="«constraint»&#xa;Self-review available only&#xa;during active review cycle" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="870" y="200" width="210" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="nc1" edge="1" parent="1" source="note1" target="uc_self" style="html=1;dashed=1;endArrow=none;strokeColor=#aaa;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ENUMS -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="555" width="160" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="e_rs" value="«enumeration»&#xa;ReviewStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="590" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_rsv" value="PENDING&#xa;IN_PROGRESS&#xa;SUBMITTED&#xa;COMPLETED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_rs">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

    <mxCell id="e_rt" value="«enumeration»&#xa;ReviewType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="470" y="590" width="220" height="112" as="geometry"/>
    </mxCell>
    <mxCell id="e_rtv" value="ANNUAL&#xa;MID_YEAR&#xa;PROBATION" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_rt">
      <mxGeometry x="0" y="36" width="220" height="76" as="geometry"/>
    </mxCell>

    <mxCell id="e_es" value="«enumeration»&#xa;EmploymentStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="720" y="590" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_esv" value="ACTIVE&#xa;ON_LEAVE&#xa;PROBATION&#xa;TERMINATED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_es">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
