<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="Complaints Management" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="900" height="490" as="geometry"/>
    </mxCell>

    <!-- ACTORS -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="110" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_mgr" value="Manager" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="290" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="415" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization -->
    <mxCell id="gen1" edge="1" parent="1" source="a_mgr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="gen2" edge="1" parent="1" source="a_hr" target="a_mgr" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Row 1 — Employee -->
    <mxCell id="uc_file" value="File Complaint" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_track" value="Track Complaint Status" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_anon" value="File Anonymous&#xa;Complaint" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="75" width="220" height="70" as="geometry"/>
    </mxCell>

    <!-- Row 2 — Manager -->
    <mxCell id="uc_viewteam" value="View Team Complaints" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="265" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_comment" value="Add Comment&#xa;on Complaint" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="265" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 3 — HR Admin -->
    <mxCell id="uc_manage" value="Manage Complaints&#xa;(Resolve / Close)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="395" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_escalate" value="Escalate Complaint" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="395" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_allcomp" value="View All Complaints&#xa;(Global)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="395" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- ACTOR EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_file" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_track" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_emp" target="uc_anon" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_mgr" target="uc_viewteam" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="a_mgr" target="uc_comment" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_hr" target="uc_manage" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_hr" target="uc_escalate" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8" edge="1" parent="1" source="a_hr" target="uc_allcomp" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RELATIONSHIPS -->
    <mxCell id="r1" value="«extend»" edge="1" parent="1" source="uc_anon" target="uc_file" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#999;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r2" value="«extend»" edge="1" parent="1" source="uc_comment" target="uc_viewteam" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#D6B656;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r3" value="«extend»" edge="1" parent="1" source="uc_escalate" target="uc_manage" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Access note -->
    <mxCell id="note1" value="Manager: view + comment only&#xa;HR: view + resolve + escalate" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="870" y="265" width="215" height="55" as="geometry"/>
    </mxCell>

    <!-- ENUMS -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="545" width="160" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="e_cs" value="«enumeration»&#xa;ComplaintStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="580" width="220" height="148" as="geometry"/>
    </mxCell>
    <mxCell id="e_csv" value="OPEN&#xa;UNDER_REVIEW&#xa;ESCALATED&#xa;RESOLVED&#xa;CLOSED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_cs">
      <mxGeometry x="0" y="36" width="220" height="112" as="geometry"/>
    </mxCell>

    <mxCell id="e_ct" value="«enumeration»&#xa;ComplaintType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="470" y="580" width="220" height="148" as="geometry"/>
    </mxCell>
    <mxCell id="e_ctv" value="HARASSMENT&#xa;DISCRIMINATION&#xa;POLICY_VIOLATION&#xa;WORKPLACE_SAFETY&#xa;OTHER" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ct">
      <mxGeometry x="0" y="36" width="220" height="112" as="geometry"/>
    </mxCell>

    <mxCell id="e_ps" value="«enumeration»&#xa;PermissionScope" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="720" y="580" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_psv" value="OWN&#xa;TEAM&#xa;DEPARTMENT&#xa;GLOBAL" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ps">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
