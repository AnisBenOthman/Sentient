<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="Certificate Management" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="900" height="420" as="geometry"/>
    </mxCell>

    <!-- ACTORS -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="130" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="330" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_sys" value="Document&#xa;Generator" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=12;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="1175" y="150" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization: HR extends Employee -->
    <mxCell id="gen1" edge="1" parent="1" source="a_hr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Row 1 — Employee -->
    <mxCell id="uc_req" value="Request Certificate" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_track" value="Track Certificate&#xa;Request Status" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="75" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="uc_download" value="Download Certificate" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="80" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- System UC — included -->
    <mxCell id="uc_gen" value="Auto-Generate&#xa;Certificate" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;dashed=1;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="580" y="200" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Row 3 — HR Admin -->
    <mxCell id="uc_approve" value="Approve Certificate&#xa;Request" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="315" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_reject" value="Reject Certificate&#xa;Request" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="315" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_hist" value="View Certificate&#xa;Request History" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="315" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- ACTOR EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_req" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_track" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_emp" target="uc_download" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_hr" target="uc_approve" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="a_hr" target="uc_reject" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_hr" target="uc_hist" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_sys" target="uc_gen" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RELATIONSHIPS -->
    <mxCell id="r1" value="«include»" edge="1" parent="1" source="uc_req" target="uc_gen" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#6C8EBF;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r2" value="«extend»" edge="1" parent="1" source="uc_download" target="uc_approve" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#999;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- HR-Only note -->
    <mxCell id="note1" value="HR-Only: salary data +&#xa;official stamp required" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
      <mxGeometry x="290" y="200" width="200" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="nc1" edge="1" parent="1" source="note1" target="uc_approve" style="html=1;dashed=1;endArrow=none;strokeColor=#aaa;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ENUMS -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="470" width="160" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="e_ctype" value="«enumeration»&#xa;CertificateType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="505" width="220" height="166" as="geometry"/>
    </mxCell>
    <mxCell id="e_ctypev" value="EMPLOYMENT&#xa;SALARY&#xa;EXPERIENCE&#xa;INTERNSHIP&#xa;END_OF_SERVICE" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ctype">
      <mxGeometry x="0" y="36" width="220" height="130" as="geometry"/>
    </mxCell>

    <mxCell id="e_cstatus" value="«enumeration»&#xa;CertificateStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="470" y="505" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_cstatusv" value="PENDING&#xa;APPROVED&#xa;REJECTED&#xa;GENERATED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_cstatus">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
