<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="Leave Management" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="1100" height="700" as="geometry"/>
    </mxCell>

    <!-- ACTORS -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="120" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_mgr" value="Manager" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="360" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="545" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization -->
    <mxCell id="gen1" edge="1" parent="1" source="a_mgr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="gen2" edge="1" parent="1" source="a_hr" target="a_mgr" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Row 1 — Employee -->
    <mxCell id="uc_sub" value="Submit Leave Request" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_bal" value="View Leave Balance" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="580" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_hist" value="View Leave History" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="80" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 2 — Employee -->
    <mxCell id="uc_cancel" value="Cancel Leave Request" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="200" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_track" value="Track Leave Status" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="200" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 3 — Manager -->
    <mxCell id="uc_approve" value="Approve / Reject&#xa;Leave Request" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="340" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_teamcal" value="View Team Leave&#xa;Calendar" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="340" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Row 4 — HR Admin -->
    <mxCell id="uc_config" value="Manage Leave&#xa;Configuration" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="520" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- Sub-config (included) -->
    <mxCell id="uc_hol" value="Configure Holidays" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="580" y="490" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_types" value="Configure Leave Types" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="870" y="490" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_credits" value="Configure Leave Credits" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="870" y="580" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- ACTOR EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_sub" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_bal" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_emp" target="uc_hist" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_emp" target="uc_cancel" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="a_emp" target="uc_track" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_mgr" target="uc_approve" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_mgr" target="uc_teamcal" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8" edge="1" parent="1" source="a_hr" target="uc_config" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RELATIONSHIPS -->
    <mxCell id="r1" value="«include»" edge="1" parent="1" source="uc_sub" target="uc_bal" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#6C8EBF;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r2" value="«include»" edge="1" parent="1" source="uc_config" target="uc_hol" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r3" value="«include»" edge="1" parent="1" source="uc_config" target="uc_types" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r4" value="«include»" edge="1" parent="1" source="uc_config" target="uc_credits" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ENUMS -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="755" width="160" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="e_ls" value="«enumeration»&#xa;LeaveStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="790" width="220" height="166" as="geometry"/>
    </mxCell>
    <mxCell id="e_lsv" value="PENDING&#xa;APPROVED&#xa;REJECTED&#xa;CANCELLED&#xa;ESCALATED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ls">
      <mxGeometry x="0" y="36" width="220" height="130" as="geometry"/>
    </mxCell>

    <mxCell id="e_lt" value="«enumeration»&#xa;LeaveType (examples)" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="470" y="790" width="220" height="166" as="geometry"/>
    </mxCell>
    <mxCell id="e_ltv" value="ANNUAL&#xa;SICK&#xa;MATERNITY&#xa;PATERNITY&#xa;UNPAID" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_lt">
      <mxGeometry x="0" y="36" width="220" height="130" as="geometry"/>
    </mxCell>

    <mxCell id="e_ps" value="«enumeration»&#xa;PermissionScope" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="720" y="790" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_psv" value="OWN&#xa;TEAM&#xa;DEPARTMENT&#xa;GLOBAL" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ps">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
