<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="IAM — Identity &amp; Access Management" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="900" height="560" as="geometry"/>
    </mxCell>

    <!-- ACTORS -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="110" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="350" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_sys" value="HR Core&#xa;(System)" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=12;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="1170" y="200" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization: HR Admin extends Employee -->
    <mxCell id="gen1" edge="1" parent="1" source="a_hr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- USE CASES — Row 1 -->
    <mxCell id="uc_auth" value="Authenticate" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_refresh" value="Refresh Token" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_logout" value="Logout / Revoke Session" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="80" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 2 — included / system -->
    <mxCell id="uc_jwt" value="Issue JWT Token" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;dashed=1;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="290" y="210" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_session" value="Create Session" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;dashed=1;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="580" y="210" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_revoke" value="Revoke All Sessions" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=12;dashed=1;fontColor=#333;" vertex="1" parent="1">
      <mxGeometry x="870" y="210" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 3 — HR Admin -->
    <mxCell id="uc_assign" value="Assign / Change&#xa;Profile Role" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="380" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_perms" value="Manage Role&#xa;Permissions" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="380" width="220" height="65" as="geometry"/>
    </mxCell>
    <mxCell id="uc_audit" value="View Audit Log" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="380" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- ACTOR → UC EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_auth" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_refresh" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_emp" target="uc_logout" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_hr" target="uc_assign" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="a_hr" target="uc_perms" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_hr" target="uc_audit" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_sys" target="uc_jwt" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8" edge="1" parent="1" source="a_sys" target="uc_session" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e9" edge="1" parent="1" source="a_sys" target="uc_revoke" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RELATIONSHIPS -->
    <mxCell id="r1" value="«include»" edge="1" parent="1" source="uc_auth" target="uc_jwt" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#6C8EBF;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r2" value="«include»" edge="1" parent="1" source="uc_auth" target="uc_session" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#6C8EBF;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r3" value="«extend»" edge="1" parent="1" source="uc_logout" target="uc_revoke" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#999;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ENUMS — below system boundary -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="610" width="160" height="25" as="geometry"/>
    </mxCell>

    <!-- PermissionScope -->
    <mxCell id="e_ps" value="«enumeration»&#xa;PermissionScope" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="645" width="200" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_psv" value="OWN&#xa;TEAM&#xa;DEPARTMENT&#xa;GLOBAL" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ps">
      <mxGeometry x="0" y="36" width="200" height="94" as="geometry"/>
    </mxCell>

    <!-- ChannelType -->
    <mxCell id="e_ch" value="«enumeration»&#xa;ChannelType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="450" y="645" width="200" height="148" as="geometry"/>
    </mxCell>
    <mxCell id="e_chv" value="WEB&#xa;SLACK&#xa;WHATSAPP&#xa;EMAIL&#xa;IN_APP" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ch">
      <mxGeometry x="0" y="36" width="200" height="112" as="geometry"/>
    </mxCell>

    <!-- RoleType -->
    <mxCell id="e_rt" value="«enumeration»&#xa;RoleType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="680" y="645" width="200" height="166" as="geometry"/>
    </mxCell>
    <mxCell id="e_rtv" value="EMPLOYEE&#xa;MANAGER&#xa;HR_ADMIN&#xa;EXECUTIVE&#xa;SYSTEM_ADMIN" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_rt">
      <mxGeometry x="0" y="36" width="200" height="130" as="geometry"/>
    </mxCell>

    <!-- ServiceName -->
    <mxCell id="e_sn" value="«enumeration»&#xa;ServiceName" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="910" y="645" width="200" height="112" as="geometry"/>
    </mxCell>
    <mxCell id="e_snv" value="HR_CORE&#xa;SOCIAL&#xa;AI_AGENTIC" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_sn">
      <mxGeometry x="0" y="36" width="200" height="76" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
