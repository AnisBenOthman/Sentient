<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- System Boundary -->
    <mxCell id="sys" value="Employee Management" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;fontSize=16;fontStyle=1;fillColor=none;dashed=1;strokeColor=#555;strokeWidth=2;spacingTop=10;arcSize=2;" vertex="1" parent="1">
      <mxGeometry x="220" y="20" width="900" height="560" as="geometry"/>
    </mxCell>

    <!-- ACTORS -->
    <mxCell id="a_emp" value="Employee" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="100" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_mgr" value="Manager" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="270" width="50" height="75" as="geometry"/>
    </mxCell>
    <mxCell id="a_hr" value="HR Admin" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="85" y="420" width="50" height="75" as="geometry"/>
    </mxCell>

    <!-- Generalization -->
    <mxCell id="gen1" edge="1" parent="1" source="a_mgr" target="a_emp" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="gen2" edge="1" parent="1" source="a_hr" target="a_mgr" style="html=1;endArrow=block;endFill=0;endSize=14;strokeWidth=2;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- USE CASES — Row 1 (Employee) -->
    <mxCell id="uc_profile" value="View Own Profile" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_notif" value="View Notifications" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="80" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_skills" value="View Own Skills" style="ellipse;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="80" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 2 (Manager) -->
    <mxCell id="uc_team" value="View Team Members" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="245" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_teamskills" value="View Team Skills" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="245" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Row 3 (HR Admin) -->
    <mxCell id="uc_add" value="Add Person" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="290" y="395" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_edit" value="Edit Person" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="580" y="395" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="uc_deact" value="Deactivate Person" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="870" y="395" width="220" height="60" as="geometry"/>
    </mxCell>

    <!-- Included UC -->
    <mxCell id="uc_role" value="Assign / Change&#xa;Profile Role" style="ellipse;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="580" y="500" width="220" height="65" as="geometry"/>
    </mxCell>

    <!-- ACTOR EDGES -->
    <mxCell id="e1" edge="1" parent="1" source="a_emp" target="uc_profile" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e2" edge="1" parent="1" source="a_emp" target="uc_notif" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e3" edge="1" parent="1" source="a_emp" target="uc_skills" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e4" edge="1" parent="1" source="a_mgr" target="uc_team" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e5" edge="1" parent="1" source="a_mgr" target="uc_teamskills" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e6" edge="1" parent="1" source="a_hr" target="uc_add" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e7" edge="1" parent="1" source="a_hr" target="uc_edit" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="e8" edge="1" parent="1" source="a_hr" target="uc_deact" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- RELATIONSHIPS -->
    <mxCell id="r1" value="«include»" edge="1" parent="1" source="uc_add" target="uc_role" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#82B366;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="r2" value="«extend»" edge="1" parent="1" source="uc_deact" target="uc_role" style="html=1;dashed=1;endArrow=open;endFill=0;fontSize=10;fontStyle=2;strokeColor=#999;"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- ENUMS -->
    <mxCell id="enum_lbl" value="Enumerations" style="text;html=1;fontSize=13;fontStyle=1;align=left;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="220" y="610" width="160" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="e_es" value="«enumeration»&#xa;EmploymentStatus" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="220" y="645" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_esv" value="ACTIVE&#xa;ON_LEAVE&#xa;PROBATION&#xa;TERMINATED" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_es">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

    <mxCell id="e_ct" value="«enumeration»&#xa;ContractType" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="470" y="645" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_ctv" value="FULL_TIME&#xa;PART_TIME&#xa;CONTRACT&#xa;INTERN" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ct">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

    <mxCell id="e_ps" value="«enumeration»&#xa;PermissionScope" style="swimlane;fontStyle=1;startSize=36;fillColor=#FFF9C4;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="720" y="645" width="220" height="130" as="geometry"/>
    </mxCell>
    <mxCell id="e_psv" value="OWN&#xa;TEAM&#xa;DEPARTMENT&#xa;GLOBAL" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=10;fontSize=11;" vertex="1" parent="e_ps">
      <mxGeometry x="0" y="36" width="220" height="94" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
