datasource db {
  provider = "postgresql"
  url      = env("SOCIAL_DATABASE_URL")
  schemas  = ["social"]
}

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

