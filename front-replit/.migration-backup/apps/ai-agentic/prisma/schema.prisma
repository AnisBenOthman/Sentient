datasource db {
  provider = "postgresql"
  url      = env("AI_AGENT_DATABASE_URL")
  schemas  = ["ai_agent"]
}

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["multiSchema"]
}

