    <!-- ════════════════ EDGES ════════════════ -->

    <!-- LeaveType(1) → LeaveBalance(*) -->
    <mxCell id="le1" edge="1" source="LeaveType" target="LeaveBalance" parent="1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;startLabel=1;endLabel=*;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.4;entryDx=0;entryDy=0;">
